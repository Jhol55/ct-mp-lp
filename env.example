DATABASE_URL="postgresql://USER:SENHA@127.0.0.1:5432/NOME_DB?schema=public"

# Nest server
PORT=3001

# JWT
JWT_SECRET="coloque_uma_chave_forte_aqui"
JWT_EXPIRES_IN="7d"

# Seed do primeiro admin
ADMIN_EMAIL="admin@seu-dominio.com"
ADMIN_PASSWORD="uma_senha_forte"

# CORS (separar por vírgula se tiver mais de um)
# Ex: CORS_ORIGIN="http://localhost:3000,https://seu-dominio.com"
CORS_ORIGIN="http://localhost:3000"

# MinIO / S3 (upload de imagens)
S3_ENDPOINT="http://127.0.0.1:9000"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_BUCKET="ct-mp"
S3_REGION="us-east-1"
S3_FORCE_PATH_STYLE="true"
# URL pública da API S3 do MinIO (acessível pelo navegador para uploads)
# Em produção, usar o domínio público do MinIO (ex: https://minio.seu-dominio.com)
S3_PUBLIC_ENDPOINT="http://127.0.0.1:9000"
# URL pública para acessar os arquivos (ex: domínio do MinIO ou CDN)
S3_PUBLIC_BASE_URL="http://127.0.0.1:9000/ct-mp"