generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
}

enum BillingModel {
  MONTHLY
  SEMIANNUAL
  ANNUAL
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

model Unit {
  id             String   @id @default(uuid())
  name           String
  plansImageUrl  String?
  plansImageKey  String?
  address        String?
  addressNumber  String?
  neighborhood   String?
  city           String?
  state          String?
  zipCode        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  plans         Plan[]
  scheduleSlots ScheduleSlot[]

  @@map("units")
}

model Plan {
  id             String   @id @default(uuid())
  unitId         String
  name           String
  frequencyLabel String
  minAge         Int?
  maxAge         Int?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  unit   Unit        @relation(fields: [unitId], references: [id], onDelete: Cascade)
  prices PlanPrice[]

  @@index([unitId])
  @@map("plans")
}

model PlanPrice {
  id         String       @id @default(uuid())
  planId     String
  model      BillingModel
  priceCents Int
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, model])
  @@index([planId])
  @@map("plan_prices")
}

model ScheduleSlot {
  id        String   @id @default(uuid())
  unitId    String
  dayOfWeek Int      // 0=Dom, 1=Seg, 2=Ter, 3=Qua, 4=Qui, 5=Sex, 6=Sáb
  time      String   // formato "HH:MM", ex: "05:00", "18:30"
  className String?  // nome da aula, ex: "FUNCIONAL", "KIDS", "18H + KIDS"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, dayOfWeek, time])
  @@index([unitId])
  @@index([unitId, dayOfWeek])
  @@map("schedule_slots")
}
