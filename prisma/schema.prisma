generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
}

enum BillingModel {
  MONTHLY
  SEMIANNUAL
  ANNUAL
}

enum Modality {
  MUAY_THAI
  FUNCIONAL
}

enum ClassType {
  ADULTOS
  KIDS
  LIVRE
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

model Unit {
  id              String   @id @default(uuid())
  name            String
  scheduleImageUrl String?
  scheduleImageKey String?
  address         String?
  addressNumber   String?
  neighborhood    String?
  city            String?
  state           String?
  zipCode         String?
  paymentMethods  String?
  cancellationRules String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  modalities        UnitModality[]
  scheduleSlots      ScheduleSlot[]
  scheduleVisibility ScheduleVisibility?
  partners           Partner[]

  @@map("units")
}

model UnitModality {
  id        String   @id @default(uuid())
  unitId    String
  modality  Modality
  imageUrl  String?
  imageKey  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)
  plans  Plan[]

  @@unique([unitId, modality])
  @@index([unitId])
  @@map("modalities")
}

model Plan {
  id             String   @id @default(uuid())
  modalityId     String
  name           String
  frequencyLabel String
  minAge         Int?
  maxAge         Int?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  modality UnitModality    @relation(fields: [modalityId], references: [id], onDelete: Cascade)
  prices   PlanPrice[]

  @@index([modalityId])
  @@map("plans")
}

model PlanPrice {
  id         String       @id @default(uuid())
  planId     String
  model      BillingModel
  priceCents Int
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, model])
  @@index([planId])
  @@map("plan_prices")
}

model ScheduleSlot {
  id             String    @id @default(uuid())
  unitId         String
  dayOfWeek      Int       // 0=Dom, 1=Seg, 2=Ter, 3=Qua, 4=Qui, 5=Sex, 6=Sáb
  time           String    // formato "HH:MM", ex: "05:00", "18:30"
  modality       Modality? // modalidade: MUAY_THAI ou FUNCIONAL
  classType      ClassType @default(LIVRE) // tipo: LIVRE ou KIDS
  durationMinutes Int      @default(60) // duração da aula em minutos, padrão 1 hora
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, dayOfWeek, time])
  @@index([unitId])
  @@index([unitId, dayOfWeek])
  @@map("schedule_slots")
}

model ScheduleVisibility {
  id             String   @id @default(uuid())
  unitId         String   @unique
  hiddenTimeSlots String[] @default([]) // array de horários escondidos, formato "HH:MM"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@map("schedule_visibility")
}

model Partner {
  id            String   @id @default(uuid())
  unitId       String
  name         String   // nome do parceiro, ex: "Wellhub/Gympass", "Totalpass"
  rulesAndNotes String? // regras e observações sobre o parceiro
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId])
  @@map("partners")
}
